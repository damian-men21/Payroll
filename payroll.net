//KC03A52A JOB ,'D. MENDOZA',MSGCLASS=H
//JSTEP01 EXEC PGM=ASSIST
//STEPLIB DD DSN=KC00NIU.ASSIST.LOADLIB,DISP=SHR
//SYSIN DD 
***************************************************************** 
*                                                               *
* DEVELOPER NAME: Damian Mendoza                                *  
*                                                               * 
* MAIN PROGRAM NAME: Payroll                                    * 
* FUNCTION: CALCULAYE PAYROLL FOR A BUSINESS. EACH EMPLOYEE HAS *
* AN HOURLY PAY RATE, NUMBER AN HOURLY PAY RATE, NUMBER OF HOURS*
* WORKED, DEDUCTION FOR LUNCHES, AND BONUS AMOUNT IF EARNED.    * 
*****************************************************************
*
 PAYRPT1 CSECT 00170001 
 USING PAYRPT1,15 ESTABLISH ADDRESSABILITY ON REG 15 
*  
 LA 10,16 GET FED WITHHOLDING PERCENT INTO R10
 LA 11,4 GET STATE WITHHOLDING PERCENT INTO R11
* 
 XREAD RECORD1,80 GET FIRST EMPLOYEE RECORD 
*
 LOOP1 BC B'0100',ENDLOOP1 BRANCH IF END-OF-FILE (EOF)  
*  
 MVC OEMPNME,RECORD1 MOVE EMPLOYEE NAME TO RECORD TO 25 
 MVC OEMPID,RECORD1+30 MOVE ID STARTING FROM 31 
* 
XDECI 2,RECORD1+36 GET PAY RATE
XDECO 2,OPAYRATE DISPAY THE PAYRATE 
XDECI 3,0(1) GET HOURS 
XDECO 3,OHOURS DISPLAY HOURS
* CALCULATE GROSS PAY
MR 2,2 PAYRATE*HOURS TO R3
XDECI 2,0(1) GET DEDUCTIONS R2  
SR 3,2 SUBTRACT DECUDUCTIONS FROM R3  
XDECI 2,0(1) GET BONUS  
AR 3,2 ADD BONUS TO R3  
*  
XDECO 3,OGROSS DISPLAY GROSS PAYMENT AMT  
LR 5,3 SAVE IN R5  
* CALCULATE FEDERAL WITHHOLDINGS  
SR 2,2 CLEAR REGISTER 2  
MR 2,10 GROSS * FED RATE  
D 2,DIV100 FEDERAL QUOTIENT  
XDECO 3,OFEDWH DISPLAY FED WITHHOLDINGS  
LR 4,3 SAVE IN R4  
* CALCULATE STATE WITHHOLDINGS  
LR 3,5 RESTORE GROSS IN R3  
SR 2,2 CLEAR R2  
MR 2,11 GROSS * STATE RATE  
D 2,DIV100 STATE QUOTIENT  
XDECO 3,OSTWH DISPLAY STATE WITHOLDINGS  
* CALCULATE NET PAY  
LR 2,5 GROSS PAY  
000060 1B24 55 SR 2,4 GROSS MINUS FEDERAL WITHOLDINGS 00290211 
000062 1B23 56 SR 2,3 MINUS STATE WITHHOLDINGS 00290311 
000064 5220 F0F9 000F9 57 XDECO 2,ONETPAY DISPLAY NET PAY 00290411 
58 * 00290505 
000068 E020 F080 0085 00080 59 XPRNT DETAIL1,133 PRINT THE EMPLOYEE DETAIL RECORD 00291003 
60 * 00300001 
00006E E000 F105 0050 00105 61 XREAD RECORD1,80 READ NEXT EMPLOYEE RECORD 00310001 
62 * 00320001 
000074 47F0 F00E 0000E 63 BC B'1111',LOOP1 BRANCH TO TOP OF LOOP1 TO CHECK EOF 00330001 
64 * 00340001 
000078 65 ENDLOOP1 DS 0H 00350001 
66 * 00360001 
000078 07FE 67 BCR B'1111',14 UNCONDITIONAL RETURN TO CALLER 00370001 
68 * 00380001 
00007C 00000064 69 DIV100 DC F'100' FULLWORD DIVISION 00381011 
70 LTORG LITERAL ORGANIZATION 00390001 
71 * 00400001 
72 * THE FOLLOWING 16 LINES ARE THE DEFINITION FOR THE OUTPUT DETAIL 00410001 
73 * LINE FOR EACH EMPLOYEE FOR THE REPORT YOU ARE CREATING. IT 00420001 
74 * IS EXACTLY 133 BYTES LONG. EACH OUTPUT FIELD IS SEPARATED 00430001 
75 * BY 4 OR 5 BYTES OF EBCDIC SPACES, i.e., X'40'. 00440001 
76 * 00450001 
000080 F0 77 DETAIL1 DC C'0' CARRIAGE CONTROL CHARACTER 00460001 
000081 78 OEMPID DS CL5 OUTPUT FIELD FOR EMPLOYEE ID 00470001 
000086 40404040 79 DC 4C' ' SPACES 00480001 
00008A 80 OEMPNME DS CL25 OUTPUT FIELD FOR EMPLOYEE NAME 00490001 
0000A3 40404040 81 DC 4C' ' SPACES 00500001 
0000A7 82 OPAYRATE DS CL12 OUTPUT FIELD FOR XDECO OF PAY RATE 00510001 
0000B3 40404040 83 DC 4C' ' SPACES 00520001 
0000B7 84 OHOURS DS CL12 OUTPUT FIELD FOR XDECO OF HOURS WORKED 00530001 
0000C3 40404040 85 DC 4C' ' SPACES 00540001 
0000C7 86 OGROSS DS CL12 OUTPUT FIELD FOR XDECO OF GROSS PAY AMT 00550001 
0000D3 40404040 87 DC 4C' ' SPACES 00560001 
0000D7 88 OFEDWH DS CL12 OUTPUT FIELD FOR XDECO OF FEDERAL WH AMT 00570001 
0000E3 4040404040 89 DC 5C' ' SPACES 00580001 
0000E8 90 OSTWH DS CL12 OUTPUT FIELD FOR XDECO OF STATE WH AMT 00590001 
0000F4 4040404040 91 DC 5C' ' SPACES 00600001 

0000F9 92 ONETPAY DS CL12 OUTPUT FIELD FOR XDECO OF NET PAY AMT  
*  
*THE FOLLOWING IS THE BUFFER FOR THE INPUT RECORD  
*  
RECORD1 DS CL80 BUFFER FOR EMPLOYEE RECORD READ FROM INPUT FILE  
*  
END PAYRPT1  
